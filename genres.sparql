#+ summary: List genre
#+ transform: {
#+     "genreId": "?genreid",
#+     "genreName": "?genrename$langTag:hide"
#+ }


PREFIX dbo: <http://dbpedia.org/ontology/>
PREFIX dbp: <http://dbpedia.org/property/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT DISTINCT ?genreid ?genrename WHERE {
  ?genreid rdf:type dbo:Genre .
  ?genreid dbp:name ?genrename .
  FILTER(LANG(?genrename) = "en").
} LIMIT 100
